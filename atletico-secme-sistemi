function uidFromIndex(index) {
  return `ATL-${String(index + 1).padStart(3, "0")}`;
}

function loadState() {
  if (typeof window === "undefined") return defaultApplicants;
  const raw = localStorage.getItem(STORAGE_KEY);
  if (!raw) return defaultApplicants;
  try {
    return JSON.parse(raw);
  } catch {
    return defaultApplicants;
  }
}

function saveState(data) {
  if (typeof window !== "undefined") {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  }
}

function sumJudge(judge) {
  return Number(judge.technique || 0) + Number(judge.coordination || 0) + Number(judge.athleticism || 0) + Number(judge.discipline || 0) + Number(judge.potential || 0);
}

function overall(applicant) {
  const scores = Object.values(applicant.judges || {}).map(sumJudge).filter(Boolean);
  if (!scores.length) return 0;
  return Math.round((scores.reduce((a, b) => a + b, 0) / scores.length) * 10) / 10;
}

function decision(score) {
  if (score >= 38) return "ASİL";
  if (score >= 28) return "YEDEK";
  return "GELİŞİM GRUBU";
}

function badgeVariant(decisionText) {
  if (decisionText === "ASİL") return "default";
  if (decisionText === "YEDEK") return "secondary";
  return "outline";
}

function QRPanel({ applicant }) {
