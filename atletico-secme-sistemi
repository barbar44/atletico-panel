                        <div className="space-y-2 text-sm text-white/65">
                          <div>Veli: {a.parentName}</div>
                          <div>Telefon: {a.phone}</div>
                          <div>Lisans: {a.licensedElsewhere ? "Var" : "Yok"}</div>
                        </div>
                        <div className="mt-4">
                          <Button onClick={() => toggleCheckIn(a.id)} className="w-full rounded-2xl bg-fuchsia-600 hover:bg-fuchsia-700">
                            {a.checkedIn ? `Check-In İptal (${a.checkInTime})` : "Geldi Olarak İşaretle"}
                          </Button>
                        </div>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              </CardContent>
            </Card>
          </TabsContent>

          <TabsContent value="hakem">
            <Card className="border-white/10 bg-white/5 text-white">
              <CardHeader className="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <CardTitle className="text-2xl">Hakem Tablet Değerlendirme</CardTitle>
                <Tabs value={judgeTab} onValueChange={setJudgeTab} className="w-full md:w-auto">
                  <TabsList className="grid w-full grid-cols-3 bg-black/20 md:w-[360px]">
                    <TabsTrigger value="j1">Hakem 1</TabsTrigger>
                    <TabsTrigger value="j2">Hakem 2</TabsTrigger>
                    <TabsTrigger value="j3">Hakem 3</TabsTrigger>
                  </TabsList>
                </Tabs>
              </CardHeader>
              <CardContent className="grid gap-4 lg:grid-cols-2">
                {filteredApplicants.map((a) => {
                  const judge = a.judges?.[judgeTab] || { technique: 0, coordination: 0, athleticism: 0, discipline: 0, potential: 0, note: "" };
                  return (
                    <Card key={`${a.id}-${judgeTab}`} className="border-white/10 bg-black/20 text-white">
                      <CardContent className="p-5">
                        <div className="mb-4 flex items-center justify-between">
                          <div>
                            <div className="text-lg font-semibold">{a.athleteName}</div>
                            <div className="text-sm text-white/55">{a.id} · {a.age} yaş · {a.checkedIn ? "Check-in tamam" : "Henüz gelmedi"}</div>
                          </div>
                          <Badge variant="secondary">Toplam: {sumJudge(judge)}</Badge>
                        </div>
                        <div className="grid gap-3 md:grid-cols-2">
                          {[
                            ["technique", "Teknik"],
                            ["coordination", "Koordinasyon"],
                            ["athleticism", "Atletizm"],
                            ["discipline", "Disiplin"],
                            ["potential", "Potansiyel"],
                          ].map(([key, label]) => (
                            <div className="space-y-2" key={key}>
                              <div className="flex items-center justify-between text-sm"><Label>{label}</Label><span>{judge[key]}</span></div>
                              <Input type="range" min="0" max="10" value={judge[key]} onChange={(e) => updateJudge(a.id, judgeTab, key, Number(e.target.value))} className="h-3 border-none bg-transparent p-0" />
                            </div>
                          ))}
                          <div className="space-y-2 md:col-span-2">
                            <Label>Hakem Notu</Label>
                            <Textarea value={judge.note || ""} onChange={(e) => updateJudge(a.id, judgeTab, "note", e.target.value)} className="min-h-20 border-white/10 bg-black/20" />
                          </div>
                        </div>
                      </CardContent>
                    </Card>
                  );
                })}
              </CardContent>
            </Card>
          </TabsContent>

          <TabsContent value="sonuc">
            <div className="grid gap-6 lg:grid-cols-[1.2fr,0.8fr]">
              <Card className="border-white/10 bg-white/5 text-white">
                <CardHeader>
                  <CardTitle className="text-2xl">Canlı Sıralama</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="overflow-hidden rounded-2xl border border-white/10">
                    <Table>
                      <TableHeader>
                        <TableRow className="border-white/10 hover:bg-transparent">
                          <TableHead>Sıra</TableHead>
                          <TableHead>Sporcu</TableHead>
                          <TableHead>Yaş</TableHead>
                          <TableHead>Check-In</TableHead>
                          <TableHead>Ortalama Puan</TableHead>
                          <TableHead>Durum</TableHead>
                        </TableRow>
                      </TableHeader>
                      <TableBody>
                        {rankedApplicants.map((a, index) => {
                          const score = overall(a);
                          const d = decision(score);
                          return (
                            <TableRow key={a.id} className="border-white/10">
                              <TableCell className="font-bold">{index + 1}</TableCell>
                              <TableCell>
                                <div className="font-medium">{a.athleteName}</div>
                                <div className="text-xs text-white/50">{a.id}</div>
                              </TableCell>
                              <TableCell>{a.age}</TableCell>
                              <TableCell>{a.checkedIn ? "Evet" : "Hayır"}</TableCell>
                              <TableCell>
                                <div className="font-semibold">{score}</div>
                                <Progress value={score * 2.5} className="mt-2 h-2" />
                              </TableCell>
                              <TableCell><Badge variant={badgeVariant(d)}>{d}</Badge></TableCell>
                            </TableRow>
                          );
                        })}
                      </TableBody>
                    </Table>
                  </div>
                </CardContent>
              </Card>
              <div className="space-y-6">
                <Card className="border-white/10 bg-white/5 text-white">
                  <CardHeader><CardTitle>Karar Kriteri</CardTitle></CardHeader>
                  <CardContent className="space-y-4 text-sm text-white/70">
                    <div className="rounded-2xl border border-white/10 p-4">
                      <div className="font-semibold text-white">ASİL</div>
                      <div>38 puan ve üzeri</div>
                    </div>
                    <div className="rounded-2xl border border-white/10 p-4">
                      <div className="font-semibold text-white">YEDEK</div>
                      <div>28 - 37.9 puan arası</div>
                    </div>
                    <div className="rounded-2xl border border-white/10 p-4">
                      <div className="font-semibold text-white">GELİŞİM GRUBU</div>
                      <div>28 puan altı</div>
                    </div>
                  </CardContent>
                </Card>
                <Card className="border-white/10 bg-white/5 text-white">
                  <CardHeader><CardTitle>Notlar</CardTitle></CardHeader>
                  <CardContent className="text-sm leading-7 text-white/70">
                    Bu prototip local storage ile çalışır. Yani aynı tarayıcıda kayıtları saklar. Canlı yayına alınırken veritabanı, kullanıcı giriş sistemi, gerçek QR üretimi ve kamera ile okutma modülü eklenir.
                  </CardContent>
                </Card>
              </div>
            </div>
          </TabsContent>
        </Tabs>
      </div>
    </div>
  );
}
